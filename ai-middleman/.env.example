# Database
DB_PASSWORD=your_postgres_password_here
DATABASE_URL=postgresql://postgres:your_postgres_password_here@localhost:5432/aimiddleman

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_from_meta_dashboard
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_from_meta_dashboard
WHATSAPP_APP_SECRET=your_app_secret_from_meta_app_settings
WHATSAPP_VERIFY_TOKEN=ai_middleman_verify_2026
BUSINESS_PHONE_NUMBER=27650746242
ALEX_WHATSAPP_NUMBER=27736013348
FRIEND_SIM_NAME=Sam

# SSL — leave true in production; only set to false for local dev if your
# network intercepts TLS (e.g. a corporate proxy) and breaks the handshake.
WHATSAPP_VERIFY_SSL=true

# Optional: WhatsApp Flow ID for the "Edit draft" in-chat form
# (whatsapp_flows/edit_draft_flow.json) — leave unset to fall back to the
# typed "EDIT <text>" command instead.
WHATSAPP_EDIT_FLOW_ID=

# Groq — primary LLM provider (fast + free-tier). Get a key at
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Featherless — fallback LLM provider, used automatically if Groq's
# free-tier rate limit is exhausted mid-session. Also accepts
# OPENROUTER_API_KEY as an alternative if you're using OpenRouter instead.
FEATHERLESS_API_KEY=your_featherless_api_key_here
FEATHERLESS_API_URL=https://api.featherless.ai/v1/chat/completions
FEATHERLESS_MODEL=NousResearch/Meta-Llama-3.1-8B-Instruct

# Optional: per-service LLM call tuning (sensible defaults if unset — see
# each service's _timeout_for()/_backoff_for() for the actual defaults)
INTENT_TIMEOUT_SECONDS=
INTENT_MAX_ATTEMPTS=3
AGENT_TIMEOUT_SECONDS=
AGENT_MAX_ATTEMPTS=3
DRAFT_TIMEOUT_SECONDS=
DRAFT_MAX_ATTEMPTS=3

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5174

# Optional: ngrok tunnel (dev_tunnel.py), for exposing the local API to
# Meta's webhook during development
NGROK_DOMAIN=
NGROK_AUTHTOKEN=
PORT=8000
